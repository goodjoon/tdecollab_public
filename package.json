{
  "name": "tdecollab",
  "version": "0.1.3",
  "description": "Confluence, Jira, GitLab CLI 및 MCP 통합 도구",
  "keywords": [
    "mcp",
    "mcp-server",
    "confluence",
    "jira",
    "gitlab",
    "cli"
  ],
  "type": "module",
  "bin": {
    "tdecollab": "./dist/cli.js",
    "tdecollab-server": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "cli": "tsx src/cli.ts",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.7.9",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "markdown-it": "^14.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.4",
    "axios-mock-adapter": "^2.1.0",
    "prettier": "^3.5.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

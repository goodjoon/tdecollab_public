# === Confluence ===
CONFLUENCE_BASE_URL=https://confluence.tde.example.com
# Confluence는 PAT(Personal Access Token) 인증을 권장합니다.
# PAT 사용 시 Bearer 토큰으로 인증하며, CONFLUENCE_USERNAME은 필요하지 않습니다.
# CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=your-confluence-pat-token
# Mermaid 렌더링에 사용되는 매크로 이름 (Confluence 환경에 따라 다름, 기본값: mermaiddiagram)
CONFLUENCE_MERMAID_MACRO_NAME=mermaid
# 인라인 코드 강조 스타일 설정 (마크다운의 `code` 형태를 어떻게 볼드/색상 적용할지, 기본값: color: #d04437; font-weight: bold;)
CONFLUENCE_INLINE_CODE_STYLE="color: #d04437; font-weight: bold;"

# === JIRA ===
JIRA_BASE_URL=https://jira.tde.example.com
# JIRA도 PAT(Personal Access Token) 인증을 사용합니다.
# JIRA_USERNAME은 생략 가능합니다.
# JIRA_USERNAME=
JIRA_API_TOKEN=your-jira-pat-token

# === GitLab ===
GITLAB_BASE_URL=https://gitlab.tde.example.com
# GitLab Self-hosted는 PRIVATE-TOKEN 헤더로 인증합니다.
# GitLab > Settings > Access Tokens에서 발급하세요.
GITLAB_PRIVATE_TOKEN=glpat-your-private-token

# === Logging ===
# 로그 레벨 (debug, info, warn, error)
LOG_LEVEL=info

# === AI Configuration ===
# Markdown 변환 실패 시 AI 보정에 사용할 프로바이더 및 모델 설정
# AI_PROVIDER: openai 또는 anthropic (기본값: openai)
AI_PROVIDER=openai
# AI_MODEL: 사용할 모델 이름 (예: gpt-4o, claude-3-5-sonnet-20240620)
AI_MODEL=gpt-4o
# OpenAI API 키 (provider가 openai인 경우 필수)
OPENAI_API_KEY=your-openai-api-key
# Anthropic API 키 (provider가 anthropic인 경우 필수)
ANTHROPIC_API_KEY=your-anthropic-api-key

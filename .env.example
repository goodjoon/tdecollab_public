# === Confluence ===
CONFLUENCE_BASE_URL=https://confluence.tde.sktelecom.com
# Confluence는 PAT(Personal Access Token) 인증을 권장합니다.
# PAT 사용 시 Bearer 토큰으로 인증하며, CONFLUENCE_USERNAME은 필요하지 않습니다.
# CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=your-confluence-pat-token

# === JIRA ===
JIRA_BASE_URL=https://jira.tde.sktelecom.com
# JIRA도 PAT(Personal Access Token) 인증을 사용합니다.
# JIRA_USERNAME은 생략 가능합니다.
# JIRA_USERNAME=
JIRA_API_TOKEN=your-jira-pat-token

# === GitLab ===
GITLAB_BASE_URL=https://gitlab.tde.sktelecom.com
# GitLab Self-hosted는 PRIVATE-TOKEN 헤더로 인증합니다.
# GitLab > Settings > Access Tokens에서 발급하세요.
GITLAB_PRIVATE_TOKEN=glpat-your-private-token

# === Logging ===
# 로그 레벨 (debug, info, warn, error)
LOG_LEVEL=info

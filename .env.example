# === Confluence ===
CONFLUENCE_BASE_URL=https://confluence.tde.sktelecom.com
# 1. Bearer Token 사용 시 (권장): USERNAME을 비워두거나 주석 처리하세요.
# CONFLUENCE_USERNAME=
# 2. Basic Auth 사용 시: 사번(이메일 아님)을 입력하세요.
CONFLUENCE_USERNAME=사번
CONFLUENCE_API_TOKEN=your-api-token

# === JIRA ===
JIRA_BASE_URL=https://jira.tde.sktelecom.com
# JIRA는 PAT(Personal Access Token) 인증을 사용합니다.
# USERNAME은 생략 가능합니다 (PAT에 사용자 정보가 포함되어 있음).
# JIRA_USERNAME=사번@sktelecom.com
JIRA_API_TOKEN=your-api-token

# === GitLab ===
GITLAB_BASE_URL=https://gitlab.tde.sktelecom.com
# GitLab Self-hosted는 PRIVATE-TOKEN 헤더로 인증합니다 (Bearer 아님).
# GitLab > Settings > Access Tokens에서 발급하세요.
GITLAB_PRIVATE_TOKEN=glpat-your-private-token

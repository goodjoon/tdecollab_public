tsup.config.ts
vitest.config.ts
.eslintrc.js
.eslintrc.cjs
.prettierrc
.prettierrc.*
Makefile
pnpm-lock.yaml
pnpm-workspace.yaml

# Internal / Project Docs (npm 페이지에 노출 불필요)
DEVELOPMENT.md
tdecollab-docs/
docs/
.github/
.gitlab/
.gitlab-ci.yml

# AI Agent / 어시스턴트 운영 지침 (사용자 무관)

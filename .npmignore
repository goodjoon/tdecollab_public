# package.json 의 "files": ["dist"] 화이트리스트가 우선 적용된다.
# 이 파일은 화이트리스트가 제거되었을 때를 대비한 방어선 + 의도 명시용이다.

# Security / Sensitivity
.env
.env.*
*.key
*.pem
*.secret

# Source / Tests / Configs (런타임에 불필요)
tools/
tests/
backend/
frontend/
src/
test/
